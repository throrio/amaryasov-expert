---
import uk from '../i18n/uk.json';

const problem = uk.problem;
const items = problem.items;
const lastIndex = items.length - 1;
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="bg-bg-card border border-border rounded-2xl p-8 sm:p-12" data-reveal="scale">
      <h2 class="font-mono text-3xl sm:text-4xl font-bold text-text mb-10">
        {problem.title}
      </h2>

      <ul class="space-y-6" data-reveal-stagger>
        {items.map((item, i) => (
          <li class="flex items-start gap-4">
            <span class="text-accent font-mono text-lg mt-0.5 shrink-0">&mdash;</span>
            <p class:list={[
              "text-lg leading-relaxed",
              i === lastIndex ? "text-text italic" : "text-text-muted",
            ]}>
              {item}
            </p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
