---
import uk from '../i18n/uk.json';

const guide = uk.guide;
---

<section class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <p class="font-mono text-accent text-sm tracking-widest uppercase mb-12">
      {guide.pretitle}
    </p>

    <div class="flex flex-col md:flex-row gap-10 md:gap-16 items-start">
      <!-- Photo placeholder -->
      <div class="shrink-0" data-reveal="left">
        <div class="w-48 h-48 rounded-full border-2 border-accent bg-bg-card flex items-center justify-center">
          <span class="font-mono text-4xl font-bold text-accent">АМ</span>
        </div>
      </div>

      <!-- Info -->
      <div class="flex-1" data-reveal="right">
        <h3 class="font-mono text-2xl sm:text-3xl font-bold text-text mb-1">
          {guide.name}
        </h3>
        <p class="text-text-muted text-base mb-6">
          {guide.role}
        </p>

        <p class="text-text text-lg leading-relaxed mb-8 max-w-2xl">
          {guide.bio}
        </p>

        <blockquote class="border-l-2 border-accent pl-5 py-1">
          <p class="text-text-muted italic text-base leading-relaxed">
            &laquo;{guide.philosophy}&raquo;
          </p>
        </blockquote>
      </div>
    </div>
  </div>
</section>
