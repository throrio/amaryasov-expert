---
import t from '../i18n/uk.json';

const items = t.faq.items;
const leftCol = items.slice(0, 3);
const rightCol = items.slice(3, 6);
---

<section id="faq" class="py-20">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="font-mono text-3xl font-bold text-text mb-12">
      {t.faq.title}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
      <!-- Left column -->
      <div class="flex flex-col gap-4" data-reveal-stagger>
        {leftCol.map((item) => (
          <details class="group rounded-2xl border border-border bg-bg-card transition-colors hover:bg-bg-hover">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-5 font-sans text-base font-semibold text-text list-none select-none">
              <span>{item.q}</span>
              <span class="ml-4 shrink-0 text-accent text-xl leading-none transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="px-6 pb-5 text-sm text-text-muted leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>

      <!-- Right column -->
      <div class="flex flex-col gap-4" data-reveal-stagger>
        {rightCol.map((item) => (
          <details class="group rounded-2xl border border-border bg-bg-card transition-colors hover:bg-bg-hover">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-5 font-sans text-base font-semibold text-text list-none select-none">
              <span>{item.q}</span>
              <span class="ml-4 shrink-0 text-accent text-xl leading-none transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="px-6 pb-5 text-sm text-text-muted leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Remove default marker */
  details summary::-webkit-details-marker {
    display: none;
  }
</style>
