---
import t from '../i18n/uk.json';
---

<section id="contact" class="py-24 relative overflow-hidden">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-[#0f0f1a] to-bg pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(245,158,11,0.05)_0%,transparent_60%)] pointer-events-none"></div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <h2 class="font-mono text-3xl md:text-4xl font-bold text-text mb-4">
      {t.final_cta.title}
    </h2>
    <p class="text-text-muted mb-12 max-w-xl mx-auto">
      Два шляхи — обирайте свій.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
      <!-- Path A: Ready to buy -->
      <div class="rounded-2xl border border-accent/30 bg-bg-card p-8 flex flex-col items-center text-center">
        <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mb-4">
          <span class="text-accent text-xl">&#9889;</span>
        </div>
        <h3 class="font-mono text-lg font-semibold text-text mb-2">
          Готові діяти?
        </h3>
        <p class="text-sm text-text-muted mb-6">
          30-хвилинна discovery-сесія. Безкоштовно. Без зобов'язань.
        </p>
        <a
          href="https://cal.com/andriimariasov/discovery"
          class="inline-flex items-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-bg transition-colors hover:bg-accent-hover"
        >
          {t.final_cta.cta_primary}
        </a>
      </div>

      <!-- Path B: Not ready yet -->
      <div class="rounded-2xl border border-border bg-bg-card p-8 flex flex-col items-center text-center">
        <div class="w-12 h-12 rounded-full bg-bg-hover flex items-center justify-center mb-4">
          <span class="text-text-muted text-xl">&#9993;</span>
        </div>
        <h3 class="font-mono text-lg font-semibold text-text mb-2">
          Ще думаєте?
        </h3>
        <p class="text-sm text-text-muted mb-6">
          Кейси, інсайти та практичні поради. Без спаму.
        </p>
        <form class="flex w-full gap-2" action="#" method="POST">
          <input
            type="email"
            name="email"
            required
            placeholder={t.final_cta.newsletter_placeholder}
            class="flex-1 min-w-0 rounded-full border border-border bg-bg px-4 py-3 text-sm text-text placeholder-text-muted focus:border-accent focus:outline-none transition-colors"
          />
          <button
            type="submit"
            class="shrink-0 rounded-full border border-accent bg-transparent px-5 py-3 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-bg"
          >
            {t.final_cta.cta_secondary}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
