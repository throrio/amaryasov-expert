---
import t from '../i18n/uk.json';

const willDo = t.antihype.will_do;
const wontDo = t.antihype.wont_do;
---

<section id="antihype" class="py-20 relative overflow-hidden">
  <!-- Subtle gradient background to make this section stand out -->
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-[#0d0d18] to-bg pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(245,158,11,0.03)_0%,transparent_70%)] pointer-events-none"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <h2 class="font-mono text-3xl font-bold text-text mb-4 text-center">
      {t.antihype.title}
    </h2>
    <p class="text-text-muted text-center mb-12 max-w-xl mx-auto">
      Без ілюзій. Ось що AI реально може — і чого не може.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Will Do -->
      <div class="rounded-2xl border border-success/20 bg-bg-card p-8 relative overflow-hidden" data-reveal="left">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-success/50 to-transparent"></div>
        <h3 class="font-mono text-lg font-semibold text-success mb-6 flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-success/10 text-success text-sm">&#10003;</span>
          {willDo.title}
        </h3>
        <ul class="flex flex-col gap-4">
          {willDo.items.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 inline-flex shrink-0 items-center justify-center w-5 h-5 rounded-full bg-success/10 text-success text-xs font-bold">&#10003;</span>
              <span class="text-text leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Won't Do -->
      <div class="rounded-2xl border border-error/20 bg-bg-card p-8 relative overflow-hidden" data-reveal="right">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-error/40 to-transparent"></div>
        <h3 class="font-mono text-lg font-semibold text-error/70 mb-6 flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-error/10 text-error/70 text-sm">&#10007;</span>
          {wontDo.title}
        </h3>
        <ul class="flex flex-col gap-4">
          {wontDo.items.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 inline-flex shrink-0 items-center justify-center w-5 h-5 rounded-full bg-error/10 text-error/40 text-xs font-bold">&#10007;</span>
              <span class="text-text-muted leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
