---
import uk from '../i18n/uk.json';

const { title, items } = uk.credentials;
---

<section class="py-10">
  <div class="mx-auto max-w-6xl px-6">
    <div class="rounded-2xl border border-border/50 bg-bg-card/50 p-6 sm:p-8" data-reveal>
      <p class="font-mono text-xs font-bold uppercase tracking-widest text-accent mb-5">
        {title}
      </p>
      <div class="flex flex-col sm:flex-row flex-wrap gap-4 sm:gap-6" data-reveal-stagger>
        {items.map((item) => (
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
            <span class="text-sm text-text-muted">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
