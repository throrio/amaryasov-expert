---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import Problem from '../components/Problem.astro';
import Guide from '../components/Guide.astro';
import Process from '../components/Process.astro';
import CaseCards from '../components/CaseCards.astro';
import Scenarios from '../components/Scenarios.astro';
import AntiHype from '../components/AntiHype.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<BaseLayout
  title="Андрій Мар'ясов — AI-автоматизація для бізнесу"
  description="Впроваджую AI-агентів та CRM для бізнесів з 10-100 співробітниками. Окупність 2-6 місяців. Кейси з цифрами, не обіцянки."
>
  <Header />
  <main>
    <Hero />
    <SocialProof />
    <Problem />
    <Guide />
    <Process />
    <CaseCards />
    <Scenarios />
    <AntiHype />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
