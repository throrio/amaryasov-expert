---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import Credentials from '../components/Credentials.astro';
import ForWho from '../components/ForWho.astro';
import Problem from '../components/Problem.astro';
import Guide from '../components/Guide.astro';
import Process from '../components/Process.astro';
import CaseCards from '../components/CaseCards.astro';
import AntiHype from '../components/AntiHype.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<BaseLayout
  title="Андрій Мар'ясов — AI-автоматизація для бізнесу"
  description="Практик AI-автоматизації. Впроваджую AI-агентів для бізнесу з вимірюваним ROI. Кейси з цифрами, не обіцянки."
>
  <Header />
  <main>
    <Hero />
    <SocialProof />
    <Credentials />
    <ForWho />
    <Problem />
    <Guide />
    <Process />
    <CaseCards />
    <AntiHype />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
