---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const contactMethods = [
  {
    label: 'Telegram',
    value: '@andriimariasov',
    href: 'https://t.me/andriimariasov',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`,
  },
  {
    label: 'Email',
    value: 'am@auspex.company',
    href: 'mailto:am@auspex.company',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: 'LinkedIn',
    value: '/in/andrii-mariasov',
    href: 'https://linkedin.com/in/andrii-mariasov',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
];
---

<BaseLayout
  title="Контакт — Андрій Мар'ясов | AI-автоматизація"
  description="Безкоштовна discovery-сесія — 30 хвилин. Обговоримо як AI-автоматизація може допомогти вашому бізнесу."
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden py-20 md:py-28">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <h1 class="text-4xl font-bold leading-tight md:text-5xl">
          Давайте поговоримо
        </h1>
        <p class="mt-4 text-xl text-text-muted">
          Безкоштовна discovery-сесія — 30 хвилин
        </p>
      </div>
      <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 h-80 w-80 rounded-full bg-accent/5 blur-3xl"></div>
    </section>

    <!-- Two columns: Form + Contact methods -->
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="grid gap-12 md:grid-cols-2">
          <!-- Left: Form -->
          <div>
            <h2 class="font-mono text-xs font-bold uppercase tracking-widest text-accent mb-8">
              // Напишіть мені
            </h2>
            <form action="#" method="POST" class="space-y-5">
              <div>
                <label for="name" class="block text-sm font-medium text-text-muted mb-1.5">
                  Ім'я
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-xl border border-border/50 bg-bg-card px-4 py-3 text-text placeholder:text-text-muted/50 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
                  placeholder="Ваше ім'я"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-text-muted mb-1.5">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full rounded-xl border border-border/50 bg-bg-card px-4 py-3 text-text placeholder:text-text-muted/50 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
                  placeholder="email@company.com"
                />
              </div>

              <div>
                <label for="company" class="block text-sm font-medium text-text-muted mb-1.5">
                  Компанія
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full rounded-xl border border-border/50 bg-bg-card px-4 py-3 text-text placeholder:text-text-muted/50 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
                  placeholder="Назва компанії"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-text-muted mb-1.5">
                  Повідомлення
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full rounded-xl border border-border/50 bg-bg-card px-4 py-3 text-text placeholder:text-text-muted/50 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30 resize-none"
                  placeholder="Розкажіть коротко про ваш бізнес та задачу"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full rounded-full bg-accent px-8 py-3 text-base font-semibold text-bg transition-colors hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-accent/50 focus:ring-offset-2 focus:ring-offset-bg"
              >
                Надіслати
              </button>
            </form>
          </div>

          <!-- Right: Contact methods -->
          <div>
            <h2 class="font-mono text-xs font-bold uppercase tracking-widest text-accent mb-8">
              // Або напряму
            </h2>

            <div class="space-y-4">
              {contactMethods.map((method) => (
                <a
                  href={method.href}
                  target={method.href.startsWith('mailto') ? undefined : '_blank'}
                  rel={method.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
                  class="flex items-center gap-4 rounded-2xl border border-border/50 bg-bg-card p-5 transition-colors hover:border-accent/30"
                >
                  <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent">
                    <Fragment set:html={method.icon} />
                  </span>
                  <div>
                    <p class="text-sm text-text-muted">{method.label}</p>
                    <p class="font-medium text-text">{method.value}</p>
                  </div>
                </a>
              ))}
            </div>

            <!-- Cal.com booking -->
            <div class="mt-8 rounded-2xl border border-accent/30 bg-accent-dim p-6 text-center">
              <p class="font-mono text-xs uppercase tracking-widest text-accent mb-3">
                Бронювання
              </p>
              <p class="text-lg font-semibold text-text mb-1">
                Забронювати час
              </p>
              <p class="text-sm text-text-muted mb-5">
                Оберіть зручний слот для 30-хвилинної discovery-сесії
              </p>
              <a
                href="https://cal.com/andriimariasov"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center rounded-full bg-accent px-6 py-2.5 text-sm font-semibold text-bg transition-colors hover:bg-accent-hover"
              >
                Обрати час у календарі
              </a>
            </div>

            <!-- What to expect -->
            <div class="mt-8 space-y-4">
              <h3 class="font-mono text-xs font-bold uppercase tracking-widest text-text-muted">
                Що очікувати
              </h3>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/10 font-mono text-xs font-bold text-accent">
                  1
                </span>
                <p class="text-sm text-text-muted">
                  <span class="text-text font-medium">Відповідь протягом 24 годин</span> — зазвичай швидше
                </p>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/10 font-mono text-xs font-bold text-accent">
                  2
                </span>
                <p class="text-sm text-text-muted">
                  <span class="text-text font-medium">30-хвилинна discovery-сесія</span> — безкоштовно
                </p>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/10 font-mono text-xs font-bold text-accent">
                  3
                </span>
                <p class="text-sm text-text-muted">
                  <span class="text-text font-medium">Чесний розрахунок ROI</span> — якщо AI не підходить, скажу прямо
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
